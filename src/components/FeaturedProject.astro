---
import { Image } from 'astro:assets'
import type { FeaturedProject } from '../contents/schema'
import Link from './base/Link.astro'

type Props = FeaturedProject & {
    name: string
}

const { name, description, image, tags, releaseYear, url } = Astro.props
---

<Link to={url} external class="group rounded-xs flex flex-row" border="~ default">
    <div class="flex w-3/5 hidden items-center justify-center xl:block">
        <Image src={image} alt="banner" format="avif" layout="constrained" width={image.width} height={image.height} />
    </div>
    <div class="p-8 flex flex-col gap-8 w-full justify-between xl:w-2/5">
        <div class="space-y-8">
            <div class="flex items-center justify-between">
                <p class="text-sm font-mono">
                    {releaseYear}
                </p>
                <i class="i-ic-baseline-arrow-outward text-sm hidden xl:text-xl group-hover:block xl:block"></i>
            </div>

            <div class="space-y-8">
                <h3 class="text-4xl">
                    {name}
                </h3>
                <p class="text-lg">{description}</p>
            </div>
        </div>

        <div class="flex flex-row flex-wrap gap-5">
            {
                tags.map((v) => (
                    <div
                        border="~ default"
                        class="text-muted px-3 py-2 rounded-xs flex flex-row gap-1 uppercase items-center justify-center"
                    >
                        <p class="text-xs text-center font-mono">{v}</p>
                    </div>
                ))
            }
        </div>
    </div>
</Link>
