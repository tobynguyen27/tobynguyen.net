---
import { Image } from 'astro:assets'
import type { MinecraftMod } from '../contents/schema'
import Link from './base/Link.astro'

type Props = MinecraftMod & {
    name: string
}

const { name, description, icon, codeberg, curseforge, modrinth } = Astro.props
---

<div border="~ default" class="flex flex-col p-8 gap-5 justify-between">
    <div class="space-y-5">
        <div class="gap-5 items-center flex flex-row">
            <Image
                src={icon}
                alt="icon"
                width={112}
                height={112}
                class="rounded-lg size-28"
                layout="constrained"
                format="avif"
            />

            <h3 class="text-2xl">
                {name}
            </h3>
        </div>
        <div class="text-muted">
            <p>{description}</p>
        </div>
    </div>
    <div class="flex flex-row gap-3 items-center justify-start">
        {
            codeberg && (
                <Link class="group p-1" to={codeberg} external aria-label={`${name} on Codeberg`}>
                    <i
                        class="i-simple-icons:codeberg text-muted duration-200 group-hover:text-default"
                        aria-hidden="true"
                    />
                </Link>
            )
        }
        {
            curseforge && (
                <Link class="group p-1" to={curseforge} external aria-label={`${name} on CurseForge`}>
                    <i
                        class="i-simple-icons:curseforge group-hover:text-curseforge text-muted duration-200"
                        aria-hidden="true"
                    />
                </Link>
            )
        }
        {
            modrinth && (
                <Link class="group p-1" to={modrinth} external aria-label={`${name} on Modrinth`}>
                    <i class="i-simple-icons:modrinth hover:text-modrinth text-muted duration-200" aria-hidden="true" />
                </Link>
            )
        }
    </div>
</div>
