---
import Link from '@components/base/Link.astro'
import BlogNavBar from '@components/BlogNavBar.astro'
import Default from '@layouts/Default.astro'
import { getCollection, render } from 'astro:content'
import { format } from 'date-fns'
import { resolveURL } from 'ufo'

const posts = await Promise.all(
    (await getCollection('blog'))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .map(async (post) => {
            const { remarkPluginFrontmatter } = await render(post)

            return {
                ...post,
                readingTime: remarkPluginFrontmatter.readingTimeInMin,
            }
        }),
)
---

<Default title="Blog">
    <div class="container-lg my-36 space-y-12">
        <BlogNavBar currentPath="/blog" />

        <div class="gap-12" flex="~ col">
            {
                posts.map(({ id, readingTime, data }) => {
                    return (
                        <Link
                            to={resolveURL('/blog', id)}
                            class="group flex flex-col duration-200 space-y-5 hover:opacity-75"
                        >
                            <div class="space-y-3">
                                <div class="flex flex-row items-center justify-between">
                                    <h2 class="text-2xl duration-200 lg:text-4xl md:text-3xl">{data.title}</h2>
                                    <i class="i-ic-baseline-arrow-outward text-lg hidden duration-200 md:text-2xl sm:text-xl group-hover:sm:block" />
                                </div>
                                <div class="text-muted font-mono flex gap-5 items-center">
                                    <p>{format(data.pubDate, 'MMMM d, yyyy')}</p>
                                    <p>/</p>
                                    <p>{readingTime} mins read</p>
                                </div>
                            </div>
                            <p class="text-muted text-lg">{data.description}</p>
                        </Link>
                    )
                })
            }
        </div>
    </div>
</Default>
