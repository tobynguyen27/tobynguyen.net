---
import Default from "@layouts/Default.astro"
import { getCollection } from "astro:content"
import { format } from "date-fns"
import readingTime from "reading-time"

const posts = await getCollection("blog")

const sortedBlog = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Default title="Blog">
    <div class="container-lg mb-24 mt-36 space-y-12">
       <div class="space-y-5">
            <h1 class="text-6xl">Blog</h1>
            <p class="text-xl text-muted">My thoughts on software engineering, gaming and the intersection of humanity and technology.</p>
       </div>

        <div class="gap-12" flex="~ col">
            {
                sortedBlog.map((it) => {
                    const readingMins = Math.round(readingTime(it.body || "").minutes)

                    return (
                    <a
                        href={`/blog/${it.id}`}
                        class="group py-5 flex flex-col duration-200 space-y-5 hover:(opacity-80 cursor-pointer)"
                        target="_blank"
                    >
                       <div class="space-y-3">
                         <div class="flex flex-row items-center justify-between">
                            <h2 class="text-2xl duration-200 lg:text-4xl md:text-3xl">{it.data.title}</h2>
                            <i class="i-ic-baseline-arrow-outward text-lg hidden duration-200 md:text-2xl sm:text-xl group-hover:sm:block"></i>
                        </div>
                        <div class="text-muted font-mono flex gap-5 items-center">
                            <p>
                                {format(it.data.pubDate, "MMMM d, yyyy")}
                            </p>
                            <p>/</p>
                            <p>{readingMins} mins read</p>
                        </div>
                       </div>
                        <p class="text-muted">{it.data.description}</p>
                    </a>
                )
                })
            }
        </div>
    </div>
</Default>
