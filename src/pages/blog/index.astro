---
import Default from '@layouts/Default.astro'
import { getCollection } from 'astro:content'
import { format } from 'date-fns'
import readingTime from 'reading-time'

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map((it) => ({ ...it, readingTime: Math.round(readingTime(it.body || '').minutes) }))
---

<Default title="Blog">
    <div class="container-lg my-36 space-y-12">
        <div class="space-y-5">
            <h1 class="text-5xl">Blog</h1>
            <p class="text-xl text-muted">
                My thoughts on software engineering, gaming and the intersection of humanity and technology.
            </p>
        </div>

        <div class="gap-12" flex="~ col">
            {
                posts.map(({ id, readingTime, data }) => {
                    return (
                        <a
                            href={`/blog/${id}`}
                            class="group flex flex-col duration-200 space-y-5 hover:opacity-75"
                            target="_blank"
                        >
                            <div class="space-y-3">
                                <div class="flex flex-row items-center justify-between">
                                    <h2 class="text-2xl duration-200 lg:text-4xl md:text-3xl">{data.title}</h2>
                                    <i class="i-ic-baseline-arrow-outward text-lg hidden duration-200 md:text-2xl sm:text-xl group-hover:sm:block" />
                                </div>
                                <div class="text-muted font-mono flex gap-5 items-center">
                                    <p>{format(data.pubDate, 'MMMM d, yyyy')}</p>
                                    <p>/</p>
                                    <p>{readingTime} mins read</p>
                                </div>
                            </div>
                            <p class="text-muted">{data.description}</p>
                        </a>
                    )
                })
            }
        </div>
    </div>
</Default>
